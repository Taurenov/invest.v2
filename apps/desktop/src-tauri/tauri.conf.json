{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Fin Helper",
  "version": "0.1.0",
  "identifier": "com.finhelper.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Fin Helper",
        "width": 1200,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": ["binaries/*"],
    "icon": ["icons/icon.png"],
    "windows": {
      "nsis": {
        "displayLanguageSelector": true,
        "languages": ["Russian", "English"]
      }
    }
  }
}
